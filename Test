<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Copilot Email Prompt Generator</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f3ee;
    --surface: #ffffff;
    --card: #ffffff;
    --border: #e2ddd6;
    --border-strong: #c8c2b8;
    --accent: #0f6fff;
    --accent-light: #e8f0ff;
    --text: #1a1814;
    --muted: #7a7570;
    --subtle: #b5b0a8;
    --yes-bg: #edfaf4;
    --yes-border: #2db87a;
    --yes-text: #0d5e3a;
    --no-bg: #fff0ee;
    --no-border: #e8533a;
    --no-text: #7a1f12;
    --success: #2db87a;
    --step-bg: #f0ece6;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Geist Mono', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    padding: 0;
  }

  /* Top bar */
  .topbar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .topbar-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-mark {
    width: 28px;
    height: 28px;
    background: var(--accent);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-mark svg { width: 14px; height: 14px; fill: white; }

  .logo-text {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .topbar-badge {
    font-size: 11px;
    color: var(--muted);
    background: var(--step-bg);
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid var(--border);
  }

  /* Main layout */
  .main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 40px 80px;
  }

  /* Hero */
  .hero {
    margin-bottom: 48px;
    animation: fadeUp 0.5s ease both;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
    font-weight: 500;
  }

  .hero h1 {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(36px, 5vw, 60px);
    line-height: 1.08;
    color: var(--text);
    margin-bottom: 16px;
    font-weight: 400;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--muted);
  }

  .hero-sub {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 480px;
  }

  /* Progress bar */
  .progress-section {
    margin-bottom: 32px;
    animation: fadeUp 0.5s 0.1s ease both;
  }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .progress-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  .progress-count {
    font-size: 11px;
    color: var(--muted);
  }

  .progress-track {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Content grid */
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 24px;
    align-items: start;
    animation: fadeUp 0.5s 0.15s ease both;
  }

  @media (max-width: 760px) {
    .content-grid { grid-template-columns: 1fr; }
    .main { padding: 32px 20px 60px; }
    .topbar { padding: 0 20px; }
  }

  /* Question card */
  .q-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    position: sticky;
    top: 80px;
  }

  .q-num {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--subtle);
    margin-bottom: 10px;
  }

  .q-text {
    font-family: 'Instrument Serif', serif;
    font-size: 24px;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 28px;
    font-weight: 400;
  }

  /* Yes/No */
  .yn-row { display: flex; gap: 10px; }

  .yn-btn {
    flex: 1;
    padding: 14px 20px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg);
    color: var(--text);
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .yn-btn:hover { border-color: var(--border-strong); background: var(--surface); }
  .yn-btn.sel-yes { border-color: var(--yes-border); background: var(--yes-bg); color: var(--yes-text); }
  .yn-btn.sel-no  { border-color: var(--no-border);  background: var(--no-bg);  color: var(--no-text); }

  /* Text / number inputs */
  textarea, input[type="number"] {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg);
    color: var(--text);
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    outline: none;
    transition: border-color 0.15s ease;
    resize: vertical;
  }

  textarea:focus, input[type="number"]:focus {
    border-color: var(--accent);
    background: var(--surface);
    box-shadow: 0 0 0 3px rgba(15, 111, 255, 0.08);
  }

  textarea::placeholder, input::placeholder { color: var(--subtle); }

  /* Next button */
  .next-btn {
    margin-top: 20px;
    width: 100%;
    padding: 14px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .next-btn:hover:not(:disabled) { background: #0056e0; transform: translateY(-1px); }
  .next-btn:disabled { background: var(--border); color: var(--subtle); cursor: not-allowed; transform: none; }

  /* Answers panel */
  .answers-panel {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .panel-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .answer-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    transition: border-color 0.2s ease;
  }

  .answer-item.new { border-color: var(--accent); animation: pop 0.3s cubic-bezier(0.34,1.56,0.64,1) both; }

  .a-q { font-size: 10px; color: var(--subtle); margin-bottom: 3px; line-height: 1.4; text-transform: uppercase; letter-spacing: 0.06em; }
  .a-a { font-size: 12px; color: var(--text); font-weight: 500; line-height: 1.4; }

  .empty-panel {
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: 10px;
    padding: 28px 20px;
    text-align: center;
    color: var(--subtle);
    font-size: 12px;
    line-height: 1.7;
  }

  /* Result screen */
  .result-section { animation: fadeUp 0.4s ease both; }

  .result-header {
    margin-bottom: 36px;
  }

  .result-header h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 40px;
    font-weight: 400;
    color: var(--text);
    margin-bottom: 8px;
  }

  .result-header p { font-size: 13px; color: var(--muted); }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 760px) { .result-grid { grid-template-columns: 1fr; } }

  /* Steps card */
  .steps-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 20px;
  }

  .steps-title {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 18px;
  }

  .step-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
  }

  .step-row:last-child { margin-bottom: 0; }

  .step-num {
    min-width: 24px;
    height: 24px;
    background: var(--accent-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 500;
    color: var(--accent);
    margin-top: 1px;
  }

  .step-text { font-size: 12px; color: var(--muted); line-height: 1.6; }
  .step-text strong { color: var(--text); font-weight: 500; }

  /* Answers recap */
  .recap-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
    margin-bottom: 20px;
  }

  @media (max-width: 560px) { .recap-grid { grid-template-columns: 1fr; } }

  /* Prompt box */
  .prompt-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
    margin-bottom: 10px;
  }

  .prompt-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    font-size: 13px;
    line-height: 1.9;
    color: var(--text);
    white-space: pre-wrap;
    word-break: break-word;
    margin-bottom: 14px;
  }

  /* Copy button */
  .copy-btn {
    width: 100%;
    padding: 15px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.15s ease;
    margin-bottom: 10px;
  }

  .copy-btn:hover { background: #0056e0; transform: translateY(-1px); }
  .copy-btn.copied { background: var(--success); }

  .restart-btn {
    width: 100%;
    padding: 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--muted);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.15s ease;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .restart-btn:hover { border-color: var(--border-strong); color: var(--text); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pop {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-logo">
    <div class="logo-mark">
      <svg viewBox="0 0 14 14" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 2h4v4H2zM8 2h4v4H8zM2 8h4v4H2zM10 8h2v6h-2zM8 10h4v2H8z"/>
      </svg>
    </div>
    <span class="logo-text">Copilot Email Generator</span>
  </div>
  <span class="topbar-badge">No login required</span>
</div>

<div class="main" id="main"></div>

<script>
const QS = [
  {id:1,  type:"text",   text:"Please input CMP application reference number.",           hint:"This will form part of the email subject line"},
  {id:2,  type:"text",   text:"Please input CMP ID ref.",                                  hint:"This will complete the email subject line"},
  {id:3,  type:"choice", text:"Please select the communication type.",                     hint:"This will appear between the two references in the subject line", options:["Internal Communication","External Communication"]},
  {id:4,  type:"yesno",  text:"Is there a sewer infrastructure within the subject block?", hint:"", defaultVal:"Yes"},
  {id:5,  type:"yesno",  text:"Is there a sewer manhole within the subject block?",        hint:"Shown only when Q4 is Yes"},
  {id:6,  type:"number", text:"Enter pipe diameter (mm).",                                  hint:"Numbers only", defaultVal:"150"},
  {id:7,  type:"choice", text:"Which boundary is the asset located?",                      hint:"Select one", options:["Front","Rear","North","West","East","South"], defaultVal:"Rear"},
  {id:8,  type:"number", text:"Enter approx. pipe depth in meters.",                       hint:"e.g. 1.5 — Access Passage will be calculated automatically"},
  {id:9,  type:"text",   text:"Who is this email addressed to?",                           hint:"Name and/or job title"},
  {id:10, type:"yesno",  text:"Is this a reply to an email you received?",                 hint:""},
  {id:11, type:"text",   text:"What is the key message you want to get across?",           hint:"Be as detailed as you like"},
  {id:12, type:"number", text:"How many days to respond?",                                  hint:"Enter 0 if there is no deadline"},
  {id:13, type:"yesno",  text:"Should the tone be formal?",                                hint:""},
  {id:14, type:"yesno",  text:"Does the recipient need to take action?",                   hint:""},
  {id:15, type:"text",   text:"What outcome or next step are you hoping for?",             hint:"e.g. schedule a call, get approval"},
  {id:16, type:"yesno",  text:"Do you want to mention a document or attachment?",          hint:""},
  {id:17, type:"text",   text:"Your name and job title for the sign-off?",                 hint:"e.g. Jamie Chen, Senior Manager"},
];

// Sewer infra answer is at index 3 (Q4). If No, Q5-Q8 are skipped.
// When Q4 is No, answers[4..7] are stored as empty strings '' so indices stay consistent.
function sewerIsYes() { return answers[3] === 'Yes'; }

// Access Passage from pipe depth (index 7)
function getAccessPassage() {
  if (!sewerIsYes()) return null;
  const depth = parseFloat(answers[7]);
  if (isNaN(depth)) return null;
  return depth < 2.2 ? '1.8m wide x 2.65m high' : '2.5m wide x 2.85m high';
}

// Emergency Access Passage — only if manhole is Yes (index 4)
function getEmergencyPassage() {
  if (!sewerIsYes()) return null;
  if (answers[4] !== 'Yes') return null;
  return '1.5m wide x 2.2m high';
}

// Pipe Protection Envelope — based on pipe diameter (index 5) and pipe depth (index 7)
function getPipeProtection() {
  if (!sewerIsYes()) return null;
  const diam  = parseFloat(answers[5]);
  const depth = parseFloat(answers[7]);
  if (isNaN(diam) || isNaN(depth)) return null;
  if (diam > 375 || depth > 5)          return 'Seek Design & Engineering Advice';
  if (diam > 225 && diam <= 375)        return '3.5m wide';
  if (diam <= 225 && depth < 5)         return '2.5m wide';
  return 'Seek Design & Engineering Advice';
}

let cur = 0, answers = [], pending = null;
const main = document.getElementById('main');

// ── Subject preview helpers (global so all handlers can call them) ──────────
// liveRef/liveId track typed-but-not-yet-confirmed values for Q1 & Q2
let liveRef = '', liveId = '';

function subjectPlainText() {
  const r  = answers[0] !== undefined ? answers[0] : liveRef;
  const id = answers[1] !== undefined ? answers[1] : liveId;
  const ct = answers[2] || '';
  return [r, ct, id].filter(Boolean).join(' ');
}

function buildSubjectHTML() {
  const r  = answers[0] !== undefined ? answers[0] : liveRef;
  const id = answers[1] !== undefined ? answers[1] : liveId;
  const ct = answers[2] || '';

  const refPart = r
    ? '<span style="color:var(--accent);font-weight:600;">' + r + '</span>'
    : '<span style="color:var(--subtle);font-style:italic;">[CMP Ref]</span>';

  const ctPart = ct
    ? '<span style="color:#7c3aed;font-weight:600;">' + ct + '</span>'
    : (cur >= 2 ? '<span style="color:var(--subtle);font-style:italic;">[Comm Type]</span>' : '');

  const idPart = id
    ? '<span style="color:var(--text);font-weight:600;">' + id + '</span>'
    : (cur >= 1 ? '<span style="color:var(--subtle);font-style:italic;">[CMP ID]</span>' : '');

  return [refPart, ctPart, idPart].filter(Boolean)
    .join(' <span style="color:var(--subtle);margin:0 2px;">·</span> ');
}

function refreshSubjectPreview() {
  const el = document.getElementById('subject-preview');
  if (el) el.innerHTML = buildSubjectHTML();
  const copyLink = document.getElementById('subject-copy-link');
  if (copyLink) {
    const txt = subjectPlainText();
    copyLink.style.display = txt.replace(/\[.*?\]/g,'').trim() ? 'inline' : 'none';
  }
}

function makeAutoCard(bgColor, borderColor, labelColor, valueColor, labelText, valueText) {
  const card = document.createElement('div');
  card.style.cssText = 'background:' + bgColor + ';border:1px solid ' + borderColor + ';border-radius:10px;padding:10px 14px;';
  const topRow = document.createElement('div');
  topRow.style.cssText = 'display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;';
  const lbl = document.createElement('div');
  lbl.style.cssText = 'font-size:10px;color:' + labelColor + ';text-transform:uppercase;letter-spacing:0.09em;font-weight:600;';
  lbl.textContent = labelText;
  const cpBtn = document.createElement('a');
  cpBtn.href = '#';
  cpBtn.style.cssText = 'font-size:10px;color:' + labelColor + ';text-decoration:none;font-weight:500;border:1px solid ' + borderColor + ';border-radius:4px;padding:2px 7px;transition:all 0.15s;';
  cpBtn.textContent = 'Copy';
  cpBtn.onclick = (e) => {
    e.preventDefault();
    navigator.clipboard.writeText(valueText).then(() => {
      cpBtn.textContent = '✓';
      setTimeout(() => cpBtn.textContent = 'Copy', 1800);
    });
  };
  topRow.appendChild(lbl);
  topRow.appendChild(cpBtn);
  const val = document.createElement('div');
  val.style.cssText = 'font-size:13px;font-weight:600;color:' + valueColor + ';';
  val.textContent = valueText;
  card.appendChild(topRow);
  card.appendChild(val);
  return card;
}

function render() {
  main.innerHTML = '';
  cur < QS.length ? renderQ() : renderResult();
}

function renderQ() {
  const q = QS[cur];
  pending = null;

  // Hero (only on first question)
  if (cur === 0) {
    liveRef = ''; liveId = '';
    main.innerHTML += '<div class="hero"><div class="hero-eyebrow">Microsoft Copilot · Email Tool</div><h1>Draft better emails,<br><em>faster than ever.</em></h1><p class="hero-sub">Answer 12 quick questions and we will build a ready-to-use prompt you can paste straight into Microsoft Copilot — no login, no cost, no hassle.</p></div>';
  }

  // Progress
  const ps = document.createElement('div');
  ps.className = 'progress-section';
  ps.innerHTML =
    '<div class="progress-header"><span class="progress-title">Progress</span><span class="progress-count">' + (cur+1) + ' of ' + QS.length + ' questions</span></div>' +
    '<div class="progress-track"><div class="progress-fill" style="width:' + (cur/QS.length*100) + '%"></div></div>';
  main.appendChild(ps);

  const grid = document.createElement('div');
  grid.className = 'content-grid';

  // LEFT — question card
  const left = document.createElement('div');
  const card = document.createElement('div');
  card.className = 'q-card';
  card.innerHTML =
    '<div class="q-num">Question ' + q.id + ' of ' + QS.length + '</div>' +
    '<div class="q-text">' + q.text + '</div>' +
    (q.hint ? '<p style="font-size:11px;color:var(--subtle);margin-bottom:14px;">' + q.hint + '</p>' : '');

  const ia = document.createElement('div');
  const nb = document.createElement('button');
  nb.className = 'next-btn';
  nb.style.marginTop = '0';
  nb.textContent = cur < QS.length - 1 ? 'Next question →' : 'Build my Copilot prompt ❆';
  nb.disabled = true;
  nb.onclick = () => {
    if (!pending) return;
    if (cur === 0) liveRef = pending;
    if (cur === 1) liveId  = pending;
    answers.push(pending);
    // If Q4 (index 3) answered No, skip Q5-Q8 by inserting N/A placeholders
    if (cur === 3 && pending === 'No') {
      answers.push('N/A'); // Q5 manhole
      answers.push('N/A'); // Q6 pipe diameter
      answers.push('N/A'); // Q7 boundary
      answers.push('N/A'); // Q8 pipe depth
      cur = 8; // jump straight to Q9
    } else {
      cur++;
    }
    render();
  };

  if (q.type === 'yesno') {
    ia.innerHTML = '<div class="yn-row"><button class="yn-btn" data-v="Yes">Yes</button><button class="yn-btn" data-v="No">No</button></div>';
    ia.querySelectorAll('.yn-btn').forEach(b => {
      b.onclick = () => {
        ia.querySelectorAll('.yn-btn').forEach(x => x.className = 'yn-btn');
        b.className = 'yn-btn ' + (b.dataset.v === 'Yes' ? 'sel-yes' : 'sel-no');
        pending = b.dataset.v; nb.disabled = false;
      };
    });
    // Apply default value if defined
    if (q.defaultVal) {
      const defBtn = ia.querySelector('[data-v="' + q.defaultVal + '"]');
      if (defBtn) { defBtn.click(); }
    }

  } else if (q.type === 'choice') {
    const choiceRow = document.createElement('div');
    choiceRow.style.cssText = 'display:flex;flex-direction:column;gap:10px;';
    const choiceBtns = [];
    q.options.forEach(opt => {
      const btn = document.createElement('button');
      btn.style.cssText = 'width:100%;text-align:left;padding:14px 18px;font-size:13px;border-radius:10px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-family:inherit;cursor:pointer;transition:all 0.15s;';
      btn.textContent = opt;
      btn.onclick = () => {
        choiceBtns.forEach(b => { b.style.borderColor = 'var(--border)'; b.style.background = 'var(--bg)'; b.style.color = 'var(--text)'; });
        btn.style.borderColor = '#7c3aed'; btn.style.background = '#f3f0ff'; btn.style.color = '#4c1d95';
        pending = opt; nb.disabled = false;
        refreshSubjectPreview();
      };
      choiceBtns.push(btn);
      choiceRow.appendChild(btn);
    });
    ia.appendChild(choiceRow);
    // Apply choice default if defined
    if (q.defaultVal) {
      const defBtn = choiceBtns.find(b => b.textContent === q.defaultVal);
      if (defBtn) setTimeout(() => defBtn.click(), 50);
    }

  } else if (q.type === 'text') {
    const ta = document.createElement('textarea');
    ta.rows = 4; ta.placeholder = 'Type your answer here…';
    ta.oninput = () => {
      pending = ta.value.trim();
      nb.disabled = !pending;
      if (cur === 0) { liveRef = ta.value; refreshSubjectPreview(); }
      if (cur === 1) { liveId  = ta.value; refreshSubjectPreview(); }
    };
    ia.appendChild(ta);
    setTimeout(() => ta.focus(), 50);

  } else {
    const inp = document.createElement('input');
    inp.type = 'number'; inp.min = 0; inp.placeholder = '0';
    inp.oninput = () => { pending = inp.value.trim(); nb.disabled = !pending; };
    ia.appendChild(inp);
    // Apply numeric default if defined
    if (q.defaultVal !== undefined) {
      setTimeout(() => { inp.value = q.defaultVal; pending = String(q.defaultVal); nb.disabled = false; inp.focus(); }, 50);
    } else {
      setTimeout(() => inp.focus(), 50);
    }
  }

  card.appendChild(ia);

  // Navigation row: back button (if not first question) + next button
  const navRow = document.createElement('div');
  navRow.style.cssText = 'display:flex;gap:10px;margin-top:20px;';

  if (cur > 0) {
    const bb = document.createElement('button');
    bb.style.cssText = 'flex:0 0 auto;padding:14px 18px;border:1px solid var(--border);border-radius:var(--border-radius-md);background:transparent;color:var(--muted);font-family:inherit;font-size:12px;cursor:pointer;transition:all 0.15s;letter-spacing:0.05em;';
    bb.textContent = '← Back';
    bb.onmouseenter = () => { bb.style.borderColor = 'var(--border-strong)'; bb.style.color = 'var(--text)'; };
    bb.onmouseleave = () => { bb.style.borderColor = 'var(--border)'; bb.style.color = 'var(--muted)'; };
    bb.onclick = () => {
      // Remove last answer; if we jumped from Q4=No (cur===8 with 8 answers) undo the skip
      if (cur === 8 && answers[3] === 'No') {
        answers.splice(3); // remove Q4 answer and all N/A placeholders
        cur = 3;
      } else {
        answers.pop();
        cur--;
      }
      // Restore liveRef/liveId if going back to Q1 or Q2
      if (cur === 0) liveRef = answers[0] || '';
      if (cur === 1) liveId  = answers[1] || '';
      render();
    };
    navRow.appendChild(bb);
  }

  nb.style.marginTop = '0';
  nb.style.flex = '1';
  navRow.appendChild(nb);
  card.appendChild(navRow);
  left.appendChild(card);

  // RIGHT — subject preview + answers log
  const right = document.createElement('div');
  right.className = 'answers-panel';

  // Subject card header row with copy link
  const subjectCard = document.createElement('div');
  subjectCard.style.cssText = 'background:var(--accent-light);border:1px solid var(--accent);border-radius:12px;padding:16px 18px;margin-bottom:10px;';

  const subjectHeaderRow = document.createElement('div');
  subjectHeaderRow.style.cssText = 'display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;';

  const subjectLabel = document.createElement('div');
  subjectLabel.style.cssText = 'font-size:10px;text-transform:uppercase;letter-spacing:0.12em;color:var(--accent);font-weight:500;';
  subjectLabel.textContent = 'Email Subject Line Preview';

  const copyLink = document.createElement('a');
  copyLink.id = 'subject-copy-link';
  copyLink.href = '#';
  copyLink.style.cssText = 'font-size:11px;color:var(--accent);text-decoration:none;font-weight:500;border:1px solid var(--accent);border-radius:6px;padding:3px 9px;transition:all 0.15s;display:none;';
  copyLink.textContent = 'Copy';
  copyLink.onclick = (e) => {
    e.preventDefault();
    const txt = subjectPlainText();
    if (!txt) return;
    navigator.clipboard.writeText(txt).then(() => {
      copyLink.textContent = '✓ Copied!';
      copyLink.style.background = 'var(--accent)';
      copyLink.style.color = '#fff';
      setTimeout(() => { copyLink.textContent = 'Copy'; copyLink.style.background = ''; copyLink.style.color = 'var(--accent)'; }, 2000);
    });
  };

  subjectHeaderRow.appendChild(subjectLabel);
  subjectHeaderRow.appendChild(copyLink);
  subjectCard.appendChild(subjectHeaderRow);

  const subjectPreview = document.createElement('div');
  subjectPreview.id = 'subject-preview';
  subjectPreview.style.cssText = 'font-size:13px;min-height:22px;word-break:break-all;line-height:1.7;';
  subjectPreview.innerHTML = buildSubjectHTML();
  subjectCard.appendChild(subjectPreview);
  right.appendChild(subjectCard);

  // Show copy link if there's already content
  if (subjectPlainText().replace(/\[.*?\]/g,'').trim()) copyLink.style.display = 'inline';

  // ── Auto-calculated section (sits below subject preview, above answers) ──
  const ap  = getAccessPassage();
  const ep  = getEmergencyPassage();
  const ppe = getPipeProtection();
  if (ap || ep || ppe) {
    const autoSection = document.createElement('div');
    autoSection.style.cssText = 'display:flex;flex-direction:column;gap:6px;margin-bottom:10px;';

    const autoLbl = document.createElement('div');
    autoLbl.className = 'panel-label';
    autoLbl.textContent = 'Auto-calculated';
    autoSection.appendChild(autoLbl);

    if (ap)  autoSection.appendChild(makeAutoCard('#f0fdf4','#16a34a','#166534','#14532d','Access Passage', ap));
    if (ep)  autoSection.appendChild(makeAutoCard('#fff7ed','#ea580c','#9a3412','#7c2d12','Emergency Access Passage', ep));
    if (ppe) {
      const isAdvice = ppe.startsWith('Seek');
      autoSection.appendChild(makeAutoCard(
        isAdvice ? '#fef2f2' : '#eff6ff',
        isAdvice ? '#dc2626' : '#2563eb',
        isAdvice ? '#991b1b' : '#1e40af',
        isAdvice ? '#7f1d1d' : '#1e3a8a',
        'Pipe Protection Envelope', ppe
      ));
    }

    right.appendChild(autoSection);
  }

  const panelLbl = document.createElement('div');
  panelLbl.className = 'panel-label';
  panelLbl.style.marginTop = '4px';
  panelLbl.textContent = 'Your answers so far';
  right.appendChild(panelLbl);

  if (!answers.length) {
    const emp = document.createElement('div');
    emp.className = 'empty-panel';
    emp.textContent = 'Your answers will build up here as you go through each question.';
    right.appendChild(emp);
  } else {
    const visibleQs = QS.slice(0, answers.length);
    answers.forEach((a, i) => {
      if (a === 'N/A') return; // skip auto-filled skipped questions
      const d = document.createElement('div');
      d.className = 'answer-item' + (i === answers.length - 1 ? ' new' : '');
      d.innerHTML = '<div class="a-q">Q' + (i+1) + '. ' + QS[i].text.substring(0,45) + (QS[i].text.length>45?'…':'') + '</div><div class="a-a">' + a + '</div>';
      right.appendChild(d);
    });
  }

  grid.appendChild(left);
  grid.appendChild(right);
  main.appendChild(grid);
}

function buildPrompt() {
  const a = answers;
  // Q indices: 0=cmpRef, 1=cmpId, 2=commType,
  //   3=sewerInfra, 4=sewerManhole, 5=pipeDiameter, 6=boundary, 7=pipeDepth,
  //   8=recipient, 9=isReply, 10=keyMessage, 11=deadline, 12=formal,
  //   13=needsAction, 14=outcome, 15=attachment, 16=signoff
  const subject       = [a[0], a[2], a[1]].filter(Boolean).join(' ');
  const tone          = a[12] === 'Yes' ? 'formal and professional' : 'friendly and conversational';
  const isReply       = a[9]  === 'Yes';
  const hasDeadline   = a[11] !== '0' && a[11] !== '';
  const hasAttachment = a[15] === 'Yes';
  const needsAction   = a[13] === 'Yes';
  const accessPassage = getAccessPassage();

  const sewerYes     = a[3] === 'Yes';
  const emergencyPassage = getEmergencyPassage();

  let p = 'Write a ' + tone + ' email with the following details:\n\n';
  p += 'RECIPIENT: ' + a[8] + '\n';
  p += 'SUBJECT: ' + subject + '\n';
  p += 'COMMUNICATION TYPE: ' + a[2] + '\n\n';
  p += '--- SITE / INFRASTRUCTURE DETAILS ---\n';
  p += 'Sewer infrastructure within subject block: ' + a[3] + '\n';
  if (sewerYes) {
    p += 'Sewer manhole within subject block: ' + a[4] + '\n';
    p += 'Pipe diameter: ' + a[5] + 'mm\n';
    p += 'Asset boundary location: ' + a[6] + '\n';
    p += 'Approx. pipe depth: ' + a[7] + 'm\n';
    if (accessPassage)    p += 'Access Passage required: ' + accessPassage + '\n';
    if (emergencyPassage) p += 'Emergency Access Passage required: ' + emergencyPassage + '\n';
    const pipeProtection = getPipeProtection();
    if (pipeProtection)   p += 'Pipe Protection Envelope: ' + pipeProtection + '\n';
  }
  p += '\n--- EMAIL DETAILS ---\n';
  p += isReply ? 'This is a reply to an email I received.\n\n' : 'This is a new email I am initiating.\n\n';
  p += 'KEY MESSAGE:\n' + a[10] + '\n\n';
  if (needsAction) p += 'ACTION REQUIRED: The recipient needs to take action. Desired outcome: ' + a[14] + '\n';
  if (hasDeadline) p += 'DEADLINE: Please include a polite note that a response is needed within ' + a[11] + ' day' + (a[11]==='1'?'':'s') + '.\n';
  if (hasAttachment) p += 'ATTACHMENT: Mention that a supporting document is included for their reference.\n';
  p += '\nSIGN-OFF:\n' + a[16] + '\n\n';
  p += 'Please write the full email — greeting, body paragraphs, and closing. Make it clear, concise, and ready to send without any editing needed.';
  return p.trim();
}

function renderResult() {
  const prompt = buildPrompt();

  const sec = document.createElement('div');
  sec.className = 'result-section';

  sec.innerHTML = `
    <div class="result-header">
      <h2>Your prompt is ready.</h2>
      <p>Copy it and paste directly into Microsoft Copilot to generate your email.</p>
      <div style="margin-top:16px;display:inline-flex;align-items:center;gap:10px;background:var(--accent-light);border:1px solid var(--accent);border-radius:10px;padding:10px 16px;flex-wrap:wrap;">
        <span style="font-size:11px;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);font-weight:500;">Subject</span>
        <span style="font-size:14px;font-weight:500;color:var(--accent);">${answers[0]||''}</span>
        <span style="font-size:14px;font-weight:500;color:#7c3aed;">${answers[2]||''}</span>
        <span style="font-size:14px;font-weight:500;color:var(--text);">${answers[1]||''}</span>
      </div>
    </div>`;

  const rg = document.createElement('div');
  rg.className = 'result-grid';

  // LEFT — recap + prompt
  const left = document.createElement('div');

  // Answers recap
  const recapLabel = document.createElement('div');
  recapLabel.className = 'prompt-label';
  recapLabel.textContent = 'Your answers';
  left.appendChild(recapLabel);

  const recap = document.createElement('div');
  recap.className = 'recap-grid';
  answers.forEach((a, i) => {
    if (a === 'N/A') return; // skip auto-filled placeholders
    const d = document.createElement('div');
    d.className = 'answer-item';
    d.innerHTML = '<div class="a-q">Q' + (i+1) + '. ' + QS[i].text + '</div><div class="a-a">' + a + '</div>';
    recap.appendChild(d);
    // Insert auto-calculated cards after pipe depth (index 7)
    if (i === 7) {
      const ap  = getAccessPassage();
      const ep  = getEmergencyPassage();
      const ppe = getPipeProtection();
      if (ap)  recap.appendChild(makeAutoCard('#f0fdf4','#16a34a','#166534','#14532d','Access Passage', ap));
      if (ep)  recap.appendChild(makeAutoCard('#fff7ed','#ea580c','#9a3412','#7c2d12','Emergency Access Passage', ep));
      if (ppe) {
        const isAdvice = ppe.startsWith('Seek');
        recap.appendChild(makeAutoCard(
          isAdvice ? '#fef2f2' : '#eff6ff',
          isAdvice ? '#dc2626' : '#2563eb',
          isAdvice ? '#991b1b' : '#1e40af',
          isAdvice ? '#7f1d1d' : '#1e3a8a',
          'Pipe Protection Envelope', ppe
        ));
      }
    }
  });
  left.appendChild(recap);

  // Prompt
  const pl = document.createElement('div');
  pl.className = 'prompt-label';
  pl.style.marginTop = '24px';
  pl.textContent = 'Your Copilot prompt';
  left.appendChild(pl);

  const pb = document.createElement('div');
  pb.className = 'prompt-box';
  pb.textContent = prompt;
  left.appendChild(pb);

  // RIGHT — steps + buttons
  const right = document.createElement('div');

  const stepsCard = document.createElement('div');
  stepsCard.className = 'steps-card';
  stepsCard.innerHTML = `
    <div class="steps-title">How to use this</div>
    <div class="step-row"><div class="step-num">1</div><div class="step-text">Click <strong>Copy prompt</strong> below</div></div>
    <div class="step-row"><div class="step-num">2</div><div class="step-text">Open <strong>Microsoft Copilot</strong> in Outlook, Teams, or at copilot.microsoft.com</div></div>
    <div class="step-row"><div class="step-num">3</div><div class="step-text">Paste and hit send — Copilot drafts your email instantly</div></div>
    <div class="step-row"><div class="step-num">4</div><div class="step-text">Use <strong>"Make it shorter"</strong> or <strong>"Adjust the tone"</strong> to refine</div></div>`;
  right.appendChild(stepsCard);

  const cb = document.createElement('button');
  cb.className = 'copy-btn';
  cb.textContent = 'Copy prompt to clipboard';
  cb.onclick = () => {
    navigator.clipboard.writeText(prompt).then(() => {
      cb.textContent = '✓ Copied — paste into Copilot!';
      cb.classList.add('copied');
      setTimeout(() => { cb.textContent = 'Copy prompt to clipboard'; cb.classList.remove('copied'); }, 3000);
    });
  };
  right.appendChild(cb);

  const rb = document.createElement('button');
  rb.className = 'restart-btn';
  rb.textContent = '↺ Start over';
  rb.onclick = () => { cur = 0; answers = []; render(); };
  right.appendChild(rb);

  rg.appendChild(left);
  rg.appendChild(right);
  sec.appendChild(rg);
  main.appendChild(sec);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

render();
</script>
